flowchart TD
    userInput["User provides JD + Resume"] --> ingest["File/Text Ingestion (parsers.py)"]
    ingest --> normalize["Normalize and Segment Text"]
    normalize --> skillExtraction["Extract Required Skills + JD Weights (skill_extractor.py)"]
    skillExtraction --> questionGen["Generate Adaptive Questions (assessment_engine.py)"]
    questionGen --> responseCapture["Capture Candidate Responses (app.py UI)"]
    responseCapture --> answerEval["Evaluate Answers + Confidence (assessment_engine.py)"]
    answerEval --> scoring["Compute Final Scores + Gaps (scoring.py)"]
    scoring --> adjacency["Map Adjacent Skills + Estimate Effort (learning_plan.py)"]
    adjacency --> resources["Attach Curated Free Resources (resources.py)"]
    resources --> report["Render Report + Export JSON (app.py)"]
